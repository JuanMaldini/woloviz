{
  "buildCommand": "bash scripts/release && npm run web:build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/unity/Build/unity.framework.js.unityweb",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Content-Encoding",
          "value": "br"
        }
      ]
    },
    {
      "source": "/unity/Build/unity.wasm.unityweb",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Content-Encoding",
          "value": "br"
        }
      ]
    },
    {
      "source": "/unity/Build/unity.data.unityweb",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Content-Encoding",
          "value": "br"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/unity/:path*",
      "destination": "/unity/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
